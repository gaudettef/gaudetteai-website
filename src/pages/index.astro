---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI Knowledge That Compounds">
  <!-- Hero -->
  <section class="pt-20 pb-16 md:pt-28 md:pb-24">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">Brain Network</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] font-bold text-warm-900 leading-[1.15] mb-6">
        AI knowledge that<br/>compounds
      </h1>
      <p class="text-lg md:text-xl text-warm-600 leading-relaxed max-w-2xl mx-auto mb-10">
        Every AI conversation starts from zero. Yours doesn't have to.
        Build a network of specialized AI Brains where knowledge persists,
        routes intelligently, and gets smarter with every interaction.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-900 text-warm-50 px-7 py-3 rounded-lg font-semibold text-[15px] hover:bg-warm-800 transition-colors shadow-sm">
          Start Free Trial
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center bg-white text-warm-900 px-7 py-3 rounded-lg font-semibold text-[15px] border border-warm-300 hover:border-warm-900 transition-colors">
          View Pricing
        </a>
      </div>
      <p class="text-[12px] text-warm-500 mt-4">14-day free trial. No credit card required.</p>
    </div>
  </section>

  <!-- Product Preview -->
  <section class="pb-20">
    <div class="max-w-5xl mx-auto px-5">
      <div class="bg-white rounded-2xl border border-warm-300 shadow-lg overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-warm-200 bg-warm-100">
          <div class="w-3 h-3 rounded-full bg-warm-400"></div>
          <div class="w-3 h-3 rounded-full bg-warm-400"></div>
          <div class="w-3 h-3 rounded-full bg-warm-400"></div>
          <span class="ml-3 text-[11px] text-warm-500 font-mono">app.gaudetteai.com</span>
        </div>
        <div class="aspect-[16/9] bg-warm-100 flex items-center justify-center">
          <div class="text-center px-8">
            <div class="w-16 h-16 rounded-2xl bg-warm-900 flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 68" width="32" height="34">
                <line x1="32" y1="34" x2="48" y2="34" stroke="#FAF9F7" stroke-width="1.5" opacity="0.35"/>
                <line x1="32" y1="34" x2="32" y2="6" stroke="#FAF9F7" stroke-width="1.5" opacity="0.45"/>
                <line x1="32" y1="34" x2="58" y2="22" stroke="#FAF9F7" stroke-width="1.5" opacity="0.45"/>
                <line x1="32" y1="34" x2="52" y2="50" stroke="#FAF9F7" stroke-width="1.5" opacity="0.45"/>
                <line x1="32" y1="34" x2="26" y2="62" stroke="#FAF9F7" stroke-width="1.5" opacity="0.45"/>
                <line x1="32" y1="34" x2="11" y2="22" stroke="#FAF9F7" stroke-width="1.5" opacity="0.45"/>
                <circle cx="32" cy="6" r="4.5" fill="#FAF9F7" opacity="0.6"/>
                <circle cx="58" cy="22" r="3.5" fill="#FAF9F7" opacity="0.55"/>
                <circle cx="52" cy="50" r="3.5" fill="#FAF9F7" opacity="0.55"/>
                <circle cx="26" cy="62" r="4.5" fill="#FAF9F7" opacity="0.6"/>
                <circle cx="11" cy="22" r="3.5" fill="#FAF9F7" opacity="0.55"/>
                <circle cx="48" cy="34" r="3" fill="#FAF9F7" opacity="0.5"/>
                <circle cx="32" cy="34" r="8" fill="#FAF9F7"/>
              </svg>
            </div>
            <p class="font-serif text-xl text-warm-700 font-semibold">Brain Network Intelligence Terminal</p>
            <p class="text-[13px] text-warm-500 mt-2">Your entire operation in one conversation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem / Solution -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl border border-warm-300 p-8">
          <div class="w-1 h-8 bg-warm-400 rounded-full mb-5"></div>
          <h2 class="font-serif text-2xl font-bold text-warm-900 mb-4">The problem</h2>
          <p class="text-[15px] text-warm-600 leading-relaxed mb-3">
            Every AI conversation starts from zero. Context disappears between sessions.
            Knowledge gets lost. You repeat yourself constantly.
          </p>
          <p class="text-[15px] text-warm-600 leading-relaxed">
            It's like having a brilliant colleague who forgets everything overnight.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-8">
          <div class="w-1 h-8 bg-amber-500 rounded-full mb-5"></div>
          <h2 class="font-serif text-2xl font-bold text-warm-900 mb-4">The solution</h2>
          <p class="text-[15px] text-warm-600 leading-relaxed mb-3">
            Build a network of specialized AI Brains where knowledge persists, compounds,
            and routes intelligently.
          </p>
          <p class="text-[15px] text-warm-700 leading-relaxed font-medium">
            This is Knowledge That Compounds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="text-center mb-12">
        <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-3">How it works</p>
        <h2 class="font-serif text-3xl font-bold text-warm-900">Three pillars of distributed intelligence</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl border border-warm-300 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-warm-100 flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-xl font-bold text-warm-900">1</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Specialized Brains</h3>
          <p class="text-[13px] text-warm-600 leading-relaxed">
            Each Brain is an AI expert with persistent memory for a specific domain &mdash;
            OPS, Marketing, Legal, Finance. They remember everything.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-warm-100 flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-xl font-bold text-warm-900">2</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Intelligent Routing</h3>
          <p class="text-[13px] text-warm-600 leading-relaxed">
            Content flows to the right Brain automatically. Decisions get routed,
            reviewed, and approved through structured workflows.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-warm-100 flex items-center justify-center mx-auto mb-4">
            <span class="font-serif text-xl font-bold text-warm-900">3</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Compounding Knowledge</h3>
          <p class="text-[13px] text-warm-600 leading-relaxed">
            Every interaction makes the system smarter. Knowledge persists across sessions,
            compounds over time, and never gets lost.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Preview -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="bg-white rounded-xl border border-warm-300 p-8 md:p-12 text-center">
        <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-3">Simple pricing</p>
        <h2 class="font-serif text-3xl font-bold text-warm-900 mb-3">Start building your Brain Network</h2>
        <p class="text-[15px] text-warm-600 mb-8 max-w-lg mx-auto">
          14-day free trial on every plan. Bring your own API keys for unlimited usage at cost.
        </p>
        <div class="grid md:grid-cols-3 gap-5 mb-8">
          <div class="rounded-lg border border-warm-300 p-5">
            <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-1">Personal</p>
            <p class="font-serif text-3xl font-bold text-warm-900">$49<span class="text-base text-warm-500 font-normal">/mo</span></p>
            <p class="text-[12px] text-warm-500 mt-1">Up to 5 Brains</p>
          </div>
          <div class="rounded-lg border-2 border-warm-900 p-5 relative">
            <div class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-warm-900 text-warm-50 text-[10px] font-semibold px-2.5 py-0.5 rounded-full uppercase tracking-wider">Popular</div>
            <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-1">Pro</p>
            <p class="font-serif text-3xl font-bold text-warm-900">$149<span class="text-base text-warm-500 font-normal">/mo</span></p>
            <p class="text-[12px] text-warm-500 mt-1">Up to 15 Brains</p>
          </div>
          <div class="rounded-lg border border-warm-300 p-5">
            <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-1">Team</p>
            <p class="font-serif text-3xl font-bold text-warm-900">$399<span class="text-base text-warm-500 font-normal">/mo</span></p>
            <p class="text-[12px] text-warm-500 mt-1">Unlimited Brains</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-900 text-warm-50 px-7 py-3 rounded-lg font-semibold text-[15px] hover:bg-warm-800 transition-colors">
            Start Free Trial
          </a>
          <a href="/pricing" class="inline-flex items-center justify-center text-warm-900 px-7 py-3 rounded-lg font-semibold text-[15px] border border-warm-300 hover:border-warm-900 transition-colors">
            Compare Plans
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-3">About</p>
      <h2 class="font-serif text-3xl font-bold text-warm-900 mb-4">Built by practitioners, for practitioners</h2>
      <p class="text-[15px] text-warm-600 leading-relaxed mb-3">
        Gaudette AI inc. was founded in January 2026 by Frederic Gaudette in Sherbrooke, QC.
        We built the Brain Network to solve our own problem: AI that forgets everything.
      </p>
      <p class="text-[15px] text-warm-600 leading-relaxed">
        The Knowledge That Compounds methodology powers everything we build.
        <a href="/methodology" class="text-warm-900 underline underline-offset-2 hover:text-amber-500 transition-colors font-medium">Learn the methodology</a>
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="pb-8">
    <div class="max-w-3xl mx-auto px-5">
      <div class="bg-warm-900 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-warm-50 mb-3">Ready to stop repeating yourself?</h2>
        <p class="text-[15px] text-warm-400 mb-8 max-w-lg mx-auto">
          Start your 14-day free trial. Your OPS Brain will interview you and build your network from day one.
        </p>
        <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-50 text-warm-900 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:bg-white transition-colors">
          Start Free Trial
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
