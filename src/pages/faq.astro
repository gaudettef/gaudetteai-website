---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'What is the Brain Network?',
    a: 'The Brain Network is a platform for building AI systems with persistent memory. Instead of every conversation starting from zero, you create specialized "Brains" that remember everything, share knowledge, and get smarter over time. It\'s built on the Knowledge That Compounds (KTC) methodology.'
  },
  {
    q: 'How is this different from ChatGPT?',
    a: 'Standard AI tools have no persistent memory. Every conversation starts fresh. The Brain Network gives you specialized Brains with persistent memory, intelligent routing between domains, and knowledge that compounds over time. It\'s the difference between a colleague with amnesia and one with perfect memory.'
  },
  {
    q: 'What is a "Brain"?',
    a: 'A Brain is a specialized AI assistant with persistent memory for a specific domain. For example: an OPS Brain tracks processes and decisions, a Marketing Brain remembers campaigns and brand voice, a Legal Brain accumulates case precedents. Each Brain maintains context and shares knowledge with other Brains when needed.'
  },
  {
    q: 'Do I need technical skills?',
    a: 'No. You interact with Brains through natural conversation. When you sign up, your OPS Brain interviews you to understand your needs and builds your network. If you can use ChatGPT, you can use the Brain Network.'
  },
  {
    q: 'What does "Bring Your Own Keys" (BYOK) mean?',
    a: 'All plans support connecting your own API keys from Anthropic (Claude) or Google (Gemini). This means you pay the AI provider directly at their cost — no markup from us. It gives you full control over usage and spending.'
  },
  {
    q: 'Is my data secure?',
    a: 'Yes. Your Brains and their knowledge are private to your account. We use row-level security to isolate your data, and all data is encrypted in transit and at rest. With BYOK, you maintain a direct billing relationship with your AI provider.'
  },
  {
    q: 'What happens during the free trial?',
    a: 'You get 14 days of full access with no credit card required. Your OPS Brain will interview you, help you set up your first Brains, and start capturing knowledge immediately. When the trial ends, you choose a plan or your data is preserved for 90 days.'
  },
  {
    q: 'Can I switch plans?',
    a: 'Yes, you can upgrade or downgrade at any time. Changes take effect at your next billing cycle. If you upgrade mid-cycle, you\'ll be prorated.'
  },
  {
    q: 'Do you offer enterprise/consulting services?',
    a: 'Coming soon. For organizations that need custom Brain Network architecture or team training, we will offer hands-on consulting. Contact us to discuss your needs.'
  },
];
---

<BaseLayout title="FAQ">
  <section class="pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="text-center mb-12">
        <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">FAQ</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-warm-900 leading-tight mb-4">Frequently asked questions</h1>
        <p class="text-lg text-warm-600 leading-relaxed">Everything you need to know about the Brain Network.</p>
      </div>

      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group bg-white rounded-xl border border-warm-300 overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-[15px] text-warm-900 pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-warm-500 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div class="px-6 pb-6 -mt-1">
              <div class="border-t border-warm-200 pt-4">
                <p class="text-[14px] text-warm-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-[15px] text-warm-600 mb-4">Still have questions?</p>
        <a href="/contact" class="inline-flex items-center justify-center bg-warm-900 text-warm-50 px-7 py-3 rounded-lg font-semibold text-[15px] hover:bg-warm-800 transition-colors">
          Get In Touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
