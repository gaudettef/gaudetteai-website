---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog">
  <section class="pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">Blog</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-warm-900 leading-tight mb-4">Insights</h1>
      <p class="text-lg text-warm-600 leading-relaxed">Thoughts on AI knowledge management, compounding systems, and the Brain Network.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="bg-white rounded-xl border border-warm-300 p-12 text-center">
        <p class="text-[15px] text-warm-600">New articles coming soon. Stay tuned.</p>
      </div>
    </div>
  </section>
</BaseLayout>
