---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="IA qui accumule le savoir" lang="fr">
  <!-- Hero -->
  <section class="pt-20 pb-16 md:pt-28 md:pb-24">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">Brain Network</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] font-bold text-warm-900 leading-[1.15] mb-6">
        Le savoir IA qui<br/>s'accumule
      </h1>
      <p class="text-lg md:text-xl text-warm-600 leading-relaxed max-w-2xl mx-auto mb-10">
        Chaque conversation IA repart de zero. La votre n'a pas a le faire.
        Construisez un reseau de Cerveaux IA specialises ou le savoir persiste,
        s'achemine intelligemment et s'ameliore a chaque interaction.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-900 text-warm-50 px-7 py-3 rounded-lg font-semibold text-[15px] hover:bg-warm-800 transition-colors shadow-sm">
          Essai gratuit
        </a>
        <a href="/fr/tarifs" class="inline-flex items-center justify-center bg-white text-warm-900 px-7 py-3 rounded-lg font-semibold text-[15px] border border-warm-300 hover:border-warm-900 transition-colors">
          Voir les tarifs
        </a>
      </div>
      <p class="text-[12px] text-warm-500 mt-4">14 jours d'essai gratuit. Aucune carte de credit requise.</p>
    </div>
  </section>

  <!-- Problem / Solution -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl border border-warm-300 p-8">
          <div class="w-1 h-8 bg-warm-400 rounded-full mb-5"></div>
          <h2 class="font-serif text-2xl font-bold text-warm-900 mb-4">Le probleme</h2>
          <p class="text-[15px] text-warm-600 leading-relaxed mb-3">
            Chaque conversation IA repart de zero. Le contexte disparait entre les sessions.
            Le savoir se perd. Vous vous repetez constamment.
          </p>
          <p class="text-[15px] text-warm-600 leading-relaxed">
            C'est comme avoir un collegue brillant qui oublie tout chaque nuit.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-8">
          <div class="w-1 h-8 bg-amber-500 rounded-full mb-5"></div>
          <h2 class="font-serif text-2xl font-bold text-warm-900 mb-4">La solution</h2>
          <p class="text-[15px] text-warm-600 leading-relaxed mb-3">
            Construisez un reseau de Cerveaux IA specialises ou le savoir persiste,
            s'accumule et s'achemine intelligemment.
          </p>
          <p class="text-[15px] text-warm-700 leading-relaxed font-medium">
            Voici Knowledge That Compounds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-8">
    <div class="max-w-3xl mx-auto px-5">
      <div class="bg-warm-900 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-warm-50 mb-3">Pret a arreter de vous repeter?</h2>
        <p class="text-[15px] text-warm-400 mb-8 max-w-lg mx-auto">
          Commencez votre essai gratuit de 14 jours. Votre Cerveau OPS vous interviewera et construira votre reseau des le premier jour.
        </p>
        <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-50 text-warm-900 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:bg-white transition-colors">
          Essai gratuit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
