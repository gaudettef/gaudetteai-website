---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Product — Brain Network" description="A network of specialized AI Brains where knowledge persists, routes intelligently, and compounds over time.">
  <!-- Hero -->
  <section class="pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">Product</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-warm-900 leading-tight mb-6">
        The Brain Network
      </h1>
      <p class="text-lg text-warm-600 leading-relaxed max-w-2xl mx-auto mb-10">
        A network of specialized AI Brains that remember everything, route information
        intelligently, and get smarter with every interaction. Your entire operation
        in one system.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-900 text-warm-50 px-7 py-3 rounded-lg font-semibold text-[15px] hover:bg-warm-800 transition-colors shadow-sm">
          Start Free Trial
        </a>
        <a href="/how-it-works" class="inline-flex items-center justify-center bg-white text-warm-900 px-7 py-3 rounded-lg font-semibold text-[15px] border border-warm-300 hover:border-warm-900 transition-colors">
          How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Core Concept -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="bg-white rounded-xl border border-warm-300 p-8">
        <div class="w-1 h-8 bg-amber-500 rounded-full mb-5"></div>
        <h2 class="font-serif text-2xl font-bold text-warm-900 mb-4">What is a Brain?</h2>
        <p class="text-[15px] text-warm-600 leading-relaxed mb-4">
          A Brain is a specialized AI agent with persistent memory. Unlike a regular chat that
          forgets everything after each session, a Brain remembers every decision, every document,
          and every piece of context you give it.
        </p>
        <p class="text-[15px] text-warm-600 leading-relaxed">
          Your OPS Brain coordinates operations. Your Marketing Brain knows your brand, campaigns,
          and audience. Your Legal Brain tracks contracts and deadlines. Each one is an expert in
          its domain &mdash; and they talk to each other.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Pillars -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="text-center mb-12">
        <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-3">Capabilities</p>
        <h2 class="font-serif text-3xl font-bold text-warm-900">Four systems working together</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Persistent Knowledge -->
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128218;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Persistent Knowledge</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed mb-4">
            Every Brain maintains its own state, documents, and instructions that persist across
            sessions. Context is never lost. Knowledge accumulates over weeks, months, years.
          </p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Brain state survives across sessions
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Documents registered permanently
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Custom instructions per Brain
            </li>
          </ul>
        </div>

        <!-- Intelligent Routing -->
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128268;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Intelligent Routing</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed mb-4">
            Information flows between Brains automatically. When your OPS Brain discovers
            something relevant to Marketing, it routes it there. The right context reaches
            the right place.
          </p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Brain-to-brain routing with priority
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Inbox system for pending items
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Cross-brain awareness
            </li>
          </ul>
        </div>

        <!-- Decision Audit Trail -->
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128274;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Decision Audit Trail</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed mb-4">
            Important decisions are locked in permanently with reasoning. Six months from now,
            you can look back and see exactly what was decided, why, and what alternatives
            were considered.
          </p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Permanent decision records
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Reasoning and alternatives captured
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Searchable decision history
            </li>
          </ul>
        </div>

        <!-- Terminal Interface -->
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128187;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Intelligence Terminal</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed mb-4">
            A single conversational interface where you talk to any Brain in your network.
            Switch between Brains, review priorities, check inboxes, and make decisions &mdash;
            all from one place.
          </p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Talk to any Brain by name
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Works in any browser, any device
            </li>
            <li class="flex items-start gap-2 text-[13px] text-warm-700">
              <span class="text-amber-500 mt-0.5 flex-shrink-0">&#10003;</span> Connect via Claude Code, Cursor, ChatGPT
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5">
      <div class="text-center mb-12">
        <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-3">Use cases</p>
        <h2 class="font-serif text-3xl font-bold text-warm-900">Built for how you actually work</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl border border-warm-300 p-6">
          <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-3">Freelancers</p>
          <p class="text-[14px] text-warm-600 leading-relaxed">
            One Brain per client or project. Each remembers the client's preferences, project history,
            and open items. Switch context instantly.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-6">
          <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-3">Small Business</p>
          <p class="text-[14px] text-warm-600 leading-relaxed">
            Functional Brains for operations, marketing, sales, and finance. Each expert in its
            domain, sharing context across the business automatically.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-6">
          <p class="text-[12px] font-semibold text-warm-500 uppercase tracking-wider mb-3">Teams</p>
          <p class="text-[14px] text-warm-600 leading-relaxed">
            Shared Brain Network with role-based access. Team members see only relevant Brains.
            Decisions are auditable. Knowledge survives turnover.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BYOK / Integration -->
  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-5">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128273;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Bring Your Own Keys</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed">
            Connect your own Claude or Gemini API key. You pay the AI provider directly
            at their rates &mdash; zero markup from us. We charge for the platform, not the AI.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-300 p-7">
          <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4">
            <span class="text-xl">&#128736;</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Works Everywhere</h3>
          <p class="text-[14px] text-warm-600 leading-relaxed">
            100% browser-based. No installation needed. Connect your Brain Network
            to Claude Code, Cursor, or ChatGPT with a simple MCP URL.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-8">
    <div class="max-w-3xl mx-auto px-5">
      <div class="bg-warm-900 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-warm-50 mb-3">Start building your Brain Network</h2>
        <p class="text-[15px] text-warm-400 mb-8 max-w-lg mx-auto">
          14-day free trial. Your OPS Brain will interview you and set up
          a network tailored to how you work.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://app.gaudetteai.com" class="inline-flex items-center justify-center bg-warm-50 text-warm-900 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:bg-white transition-colors">
            Start Free Trial
          </a>
          <a href="/pricing" class="inline-flex items-center justify-center text-warm-400 border border-warm-700 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:text-warm-50 hover:border-warm-400 transition-colors">
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
