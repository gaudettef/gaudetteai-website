---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Consulting">
  <section class="pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-[13px] font-semibold text-amber-500 uppercase tracking-wider mb-4">Coming Soon</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-warm-900 leading-tight mb-6">Custom implementation</h1>
      <p class="text-lg text-warm-600 leading-relaxed max-w-2xl mx-auto">
        For organizations that need a tailored Brain Network with dedicated architecture,
        Microsoft Teams integration, or hands-on team training.
        <strong>Consulting services launching soon.</strong>
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-5 grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl border border-warm-300 p-7">
        <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4"><span class="font-serif font-bold text-warm-900">01</span></div>
        <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Architecture &amp; Design</h3>
        <p class="text-[14px] text-warm-600 leading-relaxed">We design your Brain Network topology &mdash; which Brains you need, how they route, what knowledge to capture.</p>
      </div>
      <div class="bg-white rounded-xl border border-warm-300 p-7">
        <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4"><span class="font-serif font-bold text-warm-900">02</span></div>
        <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Deployment</h3>
        <p class="text-[14px] text-warm-600 leading-relaxed">We build and deploy your Brain Network. System prompts, routing rules, persistent memory structures, all configured.</p>
      </div>
      <div class="bg-white rounded-xl border border-warm-300 p-7">
        <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4"><span class="font-serif font-bold text-warm-900">03</span></div>
        <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Team Training</h3>
        <p class="text-[14px] text-warm-600 leading-relaxed">Your team learns the KTC methodology. How to interact with Brains, capture knowledge, and maintain compounding systems.</p>
      </div>
      <div class="bg-white rounded-xl border border-warm-300 p-7">
        <div class="w-10 h-10 rounded-lg bg-warm-100 flex items-center justify-center mb-4"><span class="font-serif font-bold text-warm-900">04</span></div>
        <h3 class="font-serif text-lg font-semibold text-warm-900 mb-2">Ongoing Support</h3>
        <p class="text-[14px] text-warm-600 leading-relaxed">Continuous refinement. We monitor Brain performance, adjust routing, and evolve your network as your organization grows.</p>
      </div>
    </div>
  </section>

  <section class="pb-8">
    <div class="max-w-3xl mx-auto px-5">
      <div class="bg-warm-900 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-warm-50 mb-3">Let's build your Brain Network</h2>
        <p class="text-[15px] text-warm-400 mb-8 max-w-lg mx-auto">Schedule a discovery call. We'll discuss your needs and propose a tailored implementation.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact" class="inline-flex items-center justify-center bg-warm-50 text-warm-900 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:bg-white transition-colors">Schedule Discovery Call</a>
          <a href="/pricing" class="inline-flex items-center justify-center text-warm-400 border border-warm-700 px-8 py-3.5 rounded-lg font-semibold text-[15px] hover:text-warm-50 hover:border-warm-400 transition-colors">View Self-Serve Plans</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
